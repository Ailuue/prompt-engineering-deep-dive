# Copy this file to `.env` and fill in the values.

# --- Using OpenAI's hosted API ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
# Leave OPENAI_BASE_URL unset to use the default OpenAI endpoint.
# OPENAI_BASE_URL=
MODEL=gpt-4o-mini

# --- Using a LOCAL model instead (LM Studio, Ollama, llama.cpp, vLLM) ---
# These speak the OpenAI API, so you only change the base URL + model name.
# The api key can be any non-empty string for most local servers.
#
# LM Studio:   OPENAI_BASE_URL=http://localhost:1234/v1
# Ollama:      OPENAI_BASE_URL=http://localhost:11434/v1   (run: ollama serve)
# llama.cpp:   OPENAI_BASE_URL=http://localhost:8080/v1
# vLLM:        OPENAI_BASE_URL=http://localhost:8000/v1
#
# Example local setup:
# OPENAI_API_KEY=local
# OPENAI_BASE_URL=http://localhost:11434/v1
# MODEL=llama3.1
